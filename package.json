{
  "name": "efe-mogi-showdown",
  "version": "1.0.3",
  "description": "A silly little duel for two — Efe & Mogi",
  "main": "electron/main.js",
  "author": "Efe",
  "repository": "https://github.com/DonsuzMuhallebi/efe-mogi-showdown",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "start": "npm run build && electron .",
    "pack": "npm run build && electron-builder --win nsis-web --publish never",
    "portable": "npm run build && electron-builder --win portable --publish never",
    "publish": "npm run build && electron-builder --win nsis-web --publish always"
  },
  "build": {
    "appId": "com.efemogi.showdown",
    "productName": "Efe and Mogi Showdown",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json",
      "assets/**/*"
    ],
    "win": {
      "target": "nsis-web",
      "icon": "assets/icon.ico"
    },
    "nsisWeb": {
      "artifactName": "EfeMogiShowdown-Setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Efe & Mogi Showdown",
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "include": "build/installer.nsh"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "DonsuzMuhallebi",
        "repo": "efe-mogi-showdown",
        "releaseType": "release"
      }
    ]
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "png-to-ico": "^3.0.1",
    "vite": "^5.4.10"
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  }
}
